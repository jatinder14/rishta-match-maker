VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Cloud Run (GitHub Actions "Deploy to Cloud Run"): set the same variables as repo secrets
# VITE_SUPABASE_URL / VITE_SUPABASE_PUBLISHABLE_KEY — baked in at image build. Add the Cloud Run URL to Supabase Auth redirect URLs.

# Admin panel (/admin): grant admin in Supabase — insert into public.user_roles (user_id = your auth.users.id, role = 'admin').
# There is no ADMIN_EMAILS env in this app; access is enforced by the is_admin RPC and RLS.

# Optional: override desk / support email (default is rishtewalesardarji@gmail.com)
# VITE_DEFAULT_APP_EMAIL=

# Optional: Stripe subscription link
# VITE_STRIPE_SUBSCRIPTION_CHECKOUT_URL=
